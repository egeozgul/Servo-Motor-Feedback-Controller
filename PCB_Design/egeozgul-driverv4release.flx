dShape":false,"isThumbnail":false,"label":"SMD_1206_3216Metric.kicad_mod","name":"SMD_1206_3216Metric","rawName":"SMD_1206_3216Metric.kicad_mod","storageName":"document_assets/SMD_1206_3216Metric-3f4eabea-7f85-8110-0222-24c291fec4b8.kicad_mod","uid":"eb36afbf-fa86-9fd3-b477-788c1f3b734d"},"f13d182a-0027-414d-85e8-8aa5269b635e":{"fileType":"step","is3dModel":false,"isDefault":false,"isFootprint":false,"isPcbBoardShape":false,"isThumbnail":false,"label":"3DCP_Elec_8x6.2.step","name":"3DCP_Elec_8x6.2","rawName":"3DCP_Elec_8x6.2.step","storageName":"document_assets/3DCP_Elec_8x6.2-23ed8602-d8ad-5956-24e3-d47f214a8fb2.step","uid":"f13d182a-0027-414d-85e8-8aa5269b635e"},"f15b4f5e-bd03-51cb-90d6-8fdd0e06ee49":{"fileType":"step","is3dModel":false,"isDefault":false,"isFootprint":false,"isPcbBoardShape":false,"isThumbnail":false,"label":"3DSMD_2220_5650Metric.step","name":"3DSMD_2220_5650Metric","rawName":"3DSMD_2220_5650Metric.step","storageName":"document_assets/3DSMD_2220_5650Metric-3f601e10-fcb8-8021-39e1-e76f92cdbd0b.step","uid":"f15b4f5e-bd03-51cb-90d6-8fdd0e06ee49"},"f51e647d-f049-d308-39c9-9281e1a1cd63":{"fileType":"svg","isDefault":false,"isThumbnail":false,"label":"polarized-cap","name":"polarized-cap","rawName":"polarized-cap.svg","storageName":"document_assets/polarized-cap-37900753-12a8-31ba-520a-57d33f721c9b.svg","uid":"f51e647d-f049-d308-39c9-9281e1a1cd63"},"fce681ad-fc52-d6c7-030d-e55d23d41d33":{"fileType":"step","is3dModel":false,"isDefault":false,"isFootprint":false,"isPcbBoardShape":false,"isThumbnail":false,"label":"3DCP_Elec_6.3x5.4.step","name":"3DCP_Elec_6.3x5.4","rawName":"3DCP_Elec_6.3x5.4.step","storageName":"document_assets/3DCP_Elec_6.3x5.4-69a6d39d-f48a-4be1-9350-ccd41bbd035a.step","uid":"fce681ad-fc52-d6c7-030d-e55d23d41d33"},"ff4cd96e-f644-e9cd-3799-ef0d17357fa8":{"fileType":"kicad_mod","is3dModel":false,"isDefault":false,"isFootprint":false,"isPcbBoardShape":false,"isThumbnail":false,"label":"CP_Elec_8x6.2.kicad_mod","name":"CP_Elec_8x6.2","rawName":"CP_Elec_8x6.2.kicad_mod","storageName":"document_assets/CP_Elec_8x6.2-ee042c58-9f52-af31-a508-7b2aaf431ae6.kicad_mod","uid":"ff4cd96e-f644-e9cd-3799-ef0d17357fa8"}},"behaviour":"// Howdy 👋.\n// If you are new to writing code in Flux make sure to check out our get started docs: https://docs.flux.ai/reference/introduction \n// We also have a Flux Slack Community in case you need help: https://join.slack.com/t/fluxcommunity/shared_invite/zt-p48n941f-wzQ06kGmuFJ2HXnGYT1JkA \n// To infinity and beyond 🚀 \n\nconst p1TerminalId = \"5237503d-4662-b83a-7859-31969858b9c0\"; //P1\nconst p2TerminalId = \"e5e04a27-c5c4-f2e6-5799-708eb3f01464\"; //P2\n\nconst p1Terminal = flux.getNodeById(p1TerminalId, \"elementTerminal\");\nconst p2Terminal = flux.getNodeById(p2TerminalId, \"elementTerminal\");\n\nconst outputVoltage = flux.createOutputNode(\"vout\");\nconst inputVoltage = flux.createOutputNode(\"vin\");\nconst current = flux.createOutputNode(\"I\");\n\nconst partTypeProperty : any  = flux.properties.find((prop) => prop.name === \"Part Type\");\n\n//setup event\nflux.on(\"setup\", () => {\n    const capacitance = Number(flux.properties.find((prop) => prop.name === \"Capacitance\")?.value || 0.000001);\n    flux.simulationModel =  simModel(capacitance);\n    if (partTypeProperty) {\n        changeFluxSymbol(partTypeProperty.value);\n    }\n});\n\n// Property was changed event\nflux.on(\"propertyChange\", (event: PropertyChangeEvent) => {\n\n    if (event.property_name === \"Capacitance\") {\n        flux.notify(event.property_name + \" changed to \" + event.value + \"F\", {\n            variant: \"success\",\n        });\n        flux.simulationModel =  simModel(Number(event.value));   \n    }\n    if (event.property_name === \"Part Type\") {\n        changeFluxSymbol(event.value);\n    }\n});\n\n// Calculation Event\nflux.on(\"afterStep\", () => {\n    \n    outputVoltage.name = \"Va\";\n    outputVoltage.value = Number(p2Terminal?.voltage);\n    outputVoltage.unit = \"V\";\n    outputVoltage.displayInline = false;\n    \n    inputVoltage.name = \"Vb\";\n    inputVoltage.value = Number(p1Terminal?.voltage);\n    inputVoltage.unit = \"V\";\n    inputVoltage.displayInline = false;\n\n    current.name = \"I\";\n    current.value = Number(p1Terminal?.current);\n    current.unit = \"A\";\n    current.displayInline = false;\n\n    flux.outputs = [inputVoltage, outputVoltage, current];\n});\n\nfunction changeFluxSymbol (partTypeSelected: any) {\n    if (partTypeProperty) {\n        switch (partTypeSelected) {\n            case 'Polarized Capacitor': flux.currentSymbol = \"polarized-cap\"; break;\n            case 'Non-Polarized Capacitor': flux.currentSymbol = \"non-polarized-cap\"; break;\n            default : flux.currentSymbol = \"non-polarized-cap\"; break\n        }\n    }\n};\n\nfunction simModel(capacitance: number): CapacitorSimulationModelConfig {\n    return {\n        type: \"capacitor\",\n        capacitance: capacitance,\n        map_input_to_terminal_uid: p1TerminalId,\n        map_output_to_terminal_uid: p2TerminalId,\n    }\n};\n\nconst footprintNode = flux.getNodeById(\"400f1db7-c03a-a15d-513d-e6da15e7a2f9\") as PcbLayoutNode;\nconst modelNode = flux.getNodeById(\"7c93bbd4-43d8-8bcb-8099-3fe6995b7052\") as PcbLayoutNode;\n\n// This will return array of all assets with file type .kicad_mod\nconst footprintAssetNotSorted = flux.assets.filter((asset) => asset.fileType === \"kicad_mod\").map((asset) => asset.name);\nconst footprintAssetId = footprintAssetNotSorted.sort();\n\n// This will return array of all assets with file type .step\nconst modelAssetIdNotSorted = flux.assets.filter((asset) => asset.fileType === \"step\").map((asset) => asset.name);\nconst modelAssetId = modelAssetIdNotSorted.sort();\n\nif (footprintNode || modelNode) {\n    const assetFootprintRule = footprintNode.rules.find((rule) => rule.key === \"asset\");\n    const assetModelRule = modelNode.rules.find((rule) => rule.key === \"asset\");\n\n    flux.on(\"setup\", () => {\n        const property = flux.properties.find((prop) => prop.name === \"Package\");\n        if (property) {\n            changeFootprintAsset(property.value);\n            changeModelAsset(property.value)\n        }\n    });\n\n    flux.on(\"propertyChange\", (event: PropertyChangeEvent) => {\n        if (event.property_name === \"Package\") {\n            changeFootprintAsset(event.value);\n            changeModelAsset(event.value);\n            flux.notify(event.property_name + \" changed to \" + event.value, {\n                variant: \"success\",\n                });\n        }\n    });\n\n    function changeFootprintAsset(propertyValue: any) {\n        if (assetFootprintRule) {\n            switch (propertyValue) {\n            case footprintAssetId[0]: assetFootprintRule.value = footprintAssetId[0]; footprintNode.name = footprintAssetId[0]; flux.currentSymbol = \"polarized-cap\"; partTypeProperty.value = \"Polarized Capacitor\"; break;\n            case footprintAssetId[1]: assetFootprintRule.value = footprintAssetId[1]; footprintNode.name = footprintAssetId[1]; flux.currentSymbol = \"polarized-cap\"; partTypeProperty.value = \"Polarized Capacitor\"; break;\n            case footprintAssetId[2]: assetFootprintRule.value = footprintAssetId[2]; footprintNode.name = footprintAssetId[2]; flux.currentSymbol = \"polarized-cap\"; partTypeProperty.value = \"Polarized Capacitor\"; break;\n            case footprintAssetId[3]: assetFootprintRule.value = footprintAssetId[3]; footprintNode.name = footprintAssetId[3]; flux.currentSymbol = \"polarized-cap\"; partTypeProperty.value = \"Polarized Capacitor\"; break;\n            case footprintAssetId[4]: assetFootprintRule.value = footprintAssetId[4]; footprintNode.name = footprintAssetId[4]; flux.currentSymbol = \"polarized-cap\"; partTypeProperty.value = \"Polarized Capacitor\"; break;\n            case footprintAssetId[5]: assetFootprintRule.value = footprintAssetId[5]; footprintNode.name = footprintAssetId[5]; flux.currentSymbol = \"polarized-cap\"; partTypeProperty.value = \"Polarized Capacitor\"; break;\n            case footprintAssetId[6]: assetFootprintRule.value = footprintAssetId[6]; footprintNode.name = footprintAssetId[6]; flux.currentSymbol = \"polarized-cap\"; partTypeProperty.value = \"Polarized Capacitor\"; break;\n            case footprintAssetId[7]: assetFootprintRule.value = footprintAssetId[7]; footprintNode.name = footprintAssetId[7]; flux.currentSymbol = \"non-polarized-cap\"; partTypeProperty.value = \"Non-Polarized Capacitor\"; break;\n            case footprintAssetId[8]: assetFootprintRule.value = footprintAssetId[8]; footprintNode.name = footprintAssetId[8]; flux.currentSymbol = \"non-polarized-cap\"; partTypeProperty.value = \"Non-Polarized Capacitor\"; break;\n            case footprintAssetId[9]: assetFootprintRule.value = footprintAssetId[9]; footprintNode.name = footprintAssetId[9]; flux.currentSymbol = \"non-polarized-cap\"; partTypeProperty.value = \"Non-Polarized Capacitor\"; break;\n            case footprintAssetId[10]: assetFootprintRule.value = footprintAssetId[10]; footprintNode.name = footprintAssetId[10]; flux.currentSymbol = \"non-polarized-cap\"; partTypeProperty.value = \"Non-Polarized Capacitor\"; break;\n            case footprintAssetId[11]: assetFootprintRule.value = footprintAssetId[11]; footprintNode.name = footprintAssetId[11]; flux.currentSymbol = \"non-polarized-cap\"; partTypeProperty.value = \"Non-Polarized Capacitor\"; break;\n            case footprintAssetId[12]: assetFootprintRule.value = footprintAssetId[12]; footprintNode.name = footprintAssetId[12]; flux.currentSymbol = \"non-polarized-cap\"; partTypeProperty.value = \"Non-Polarized Capacitor\"; break;\n            case footprintAssetId[13]: assetFootprintRule.value = footprintAssetId[13]; footprintNode.name = footprintAssetId[13]; flux.currentSymbol = \"non-polarized-cap\"; partTypeProperty.value = \"Non-Polarized Capacitor\"; break;\n            case footprintAssetId[14]: assetFootprintRule.value = footprintAssetId[14]; footprintNode.name = footprintAssetId[14]; flux.currentSymbol = \"non-polarized-cap\"; partTypeProperty.value = \"Non-Polarized Capacitor\"; break;\n            case footprintAssetId[15]: assetFootprintRule.value = footprintAssetId[15]; footprintNode.name = footprintAssetId[15]; flux.currentSymbol = \"non-polarized-cap\"; partTypeProperty.value = \"Non-Polarized Capacitor\"; break;\n            case footprintAssetId[16]: assetFootprintRule.value = footprintAssetId[16]; footprintNode.name = footprintAssetId[16]; flux.currentSymbol = \"non-polarized-cap\"; partTypeProperty.value = \"Non-Polarized Capacitor\"; break; \n            case footprintAssetId[17]: assetFootprintRule.value = footprintAssetId[17]; footprintNode.name = footprintAssetId[17]; flux.currentSymbol = \"non-polarized-cap\"; partTypeProperty.value = \"Non-Polarized Capacitor\"; break; \n            case footprintAssetId[18]: assetFootprintRule.value = footprintAssetId[18]; footprintNode.name = footprintAssetId[18]; flux.currentSymbol = \"non-polarized-cap\"; partTypeProperty.value = \"Non-Polarized Capacitor\"; break;                                  \n            default : assetFootprintRule.value = \"SMD_0603_1608Metric\"; footprintNode.name = \"SMD_0603_1608Metric\"; break;\n            }\n        }\n    }\n\n        function changeModelAsset(propertyValue: any) {\n        if (assetModelRule) {\n            switch (propertyValue) {\n            case footprintAssetId[0]: assetModelRule.value = modelAssetId[0]; modelNode.name = modelAssetId[0]; break;\n            case footprintAssetId[1]: assetModelRule.value = modelAssetId[1]; modelNode.name = modelAssetId[1]; break;\n            case footprintAssetId[2]: assetModelRule.value = modelAssetId[2]; modelNode.name = modelAssetId[2]; break;\n            case footprintAssetId[3]: assetModelRule.value = modelAssetId[3]; modelNode.name = modelAssetId[3]; break;\n            case footprintAssetId[4]: assetModelRule.value = modelAssetId[4]; modelNode.name = modelAssetId[4]; break;\n            case footprintAssetId[5]: assetModelRule.value = modelAssetId[5]; modelNode.name = modelAssetId[5]; break;\n            case footprintAssetId[6]: assetModelRule.value = modelAssetId[6]; modelNode.name = modelAssetId[6]; break;\n            case footprintAssetId[7]: assetModelRule.value = modelAssetId[7]; modelNode.name = modelAssetId[7]; break;\n            case footprintAssetId[8]: assetModelRule.value = modelAssetId[8]; modelNode.name = modelAssetId[8]; break;\n            case footprintAssetId[9]: assetModelRule.value = modelAssetId[9]; modelNode.name = modelAssetId[9]; break;\n            case footprintAssetId[10]: assetModelRule.value = modelAssetId[10]; modelNode.name = modelAssetId[10]; break;\n            case footprintAssetId[11]: assetModelRule.value = modelAssetId[11]; modelNode.name = modelAssetId[11]; break;\n            case footprintAssetId[12]: assetModelRule.value = modelAssetId[12]; modelNode.name = modelAssetId[12]; break;\n            case footprintAssetId[13]: assetModelRule.value = modelAssetId[13]; modelNode.name = modelAssetId[13]; break;\n            case footprintAssetId[14]: assetModelRule.value = modelAssetId[14]; modelNode.name = modelAssetId[14]; break;\n            case footprintAssetId[15]: assetModelRule.value = modelAssetId[15]; modelNode.name = modelAssetId[15]; break;\n            case footprintAssetId[16]: assetModelRule.value = modelAssetId[16]; modelNode.name = modelAssetId[16]; break;\n            case footprintAssetId[17]: assetModelRule.value = modelAssetId[17]; modelNode.name = modelAssetId[17]; break;\n            case footprintAssetId[18]: assetModelRule.value = modelAssetId[18]; modelNode.name = modelAssetId[18]; break;\n            default : assetModelRule.value = \"3DSMD_0603_1608Metric\"; modelNode.name = \"3DSMD_0603_1608Metric\"; break;\n            }\n        }\n    }\n};","behaviour_has_errors":false,"behavio