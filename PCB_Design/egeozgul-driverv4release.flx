ux.simulationModel = {\n        type: \"capacitor\",\n        capacitance: capacitance,\n        map_input_to_terminal_uid: inputTerminalElement?.uid,\n        map_output_to_terminal_uid: outputTerminalElement?.uid,\n    };\n});\n\n// Before Event\nflux.on(\"beforeStep\", (event) => {\n    const capacitance = flux.properties.find((prop) => prop.name === \"Capacitance\")?.value || 0.000001;\n    flux.simulationModel = {\n        type: \"capacitor\",\n        capacitance: capacitance,\n    };\n});\n\n// Calculation Event\nflux.on(\"afterStep\", (event) => {\n    \n    outputVoltage.name = \"VP2\";\n    outputVoltage.value = Number(outputTerminalElement?.voltage);\n    outputVoltage.unit = \"V\";\n    outputVoltage.displayInline = !!outputTerminalElement?.voltage;\n    \n    inputVoltage.name = \"VP1\";\n    inputVoltage.value = Number(inputTerminalElement?.voltage);\n    inputVoltage.unit = \"V\";\n    inputVoltage.displayInline = !!inputTerminalElement?.voltage;\n\n    current.name = \"I\";\n    current.value = Number(inputTerminalElement?.current);\n    current.unit = \"A\";\n    current.displayInline = !!inputTerminalElement?.current;\n\n    voltageDrop.name = \"Vdrop\";\n    voltageDrop.unit =\"V\";\n    voltageDrop.value = Number(Math.abs(outputTerminalElement?.voltage - inputTerminalElement?.voltage));\n    voltageDrop.displayInLine = true\n\n    flux.outputs = [inputVoltage, outputVoltage, voltageDrop, current];\n});","behaviour_has_errors":false,"behaviour_is_derived":false,"controls":{"_dataStructureIsArray":true},"created_at":1686073293497,"description":"10 µF ±10% 16V Ceramic Capacitor X7R 0805 (2012 Metric) #CommonPartsLibrary #Capacitor #Non-PolarizeCapacitor","document_import_uid":"dd7e2c87-df19-47e9-8664-92812e46e1ab","extracted_element_cache":{"054cf9fb-755b-6e6c-943a-ab6e47071d5f":{"diagram_position":{"flip":false,"orientation":0,"scene_cursor_position":true,"x":28,"y":61.4},"label":"P2","part_version_data_cache":{"name":"Terminal","part_uid":"835bf3e