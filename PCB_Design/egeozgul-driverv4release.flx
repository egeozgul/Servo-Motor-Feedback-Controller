,"name":"3DSMD_MicroMELF_MMU-0102","rawName":"3DSMD_MicroMELF_MMU-0102.step","storageName":"document_assets/3DSMD_MicroMELF_MMU-0102-0119c1c6-5eeb-1a38-0233-9c02b55b913f.step","uid":"ee3473aa-d92d-54cd-5665-951e441456a2"},"f1fe85eb-e535-e1a6-b27b-af5cff6c96a1":{"fileType":"kicad_mod","is3dModel":false,"isDefault":false,"isFootprint":false,"isPcbBoardShape":false,"isThumbnail":false,"label":"V_AXIAL-P5.08_D3.6.kicad_mod","name":"V_AXIAL-P5.08_D3.6","rawName":"V_AXIAL-P5.08_D3.6.kicad_mod","storageName":"document_assets/V_AXIAL-P5.08_D3.6-3bf3546d-0fc8-bc3b-8dda-adacf65a9ece.kicad_mod","uid":"f1fe85eb-e535-e1a6-b27b-af5cff6c96a1"},"f2ad7594-cc63-2059-ba3b-7e66131d1b9f":{"fileType":"step","is3dModel":false,"isDefault":false,"isFootprint":false,"isPcbBoardShape":false,"isThumbnail":false,"label":"3DSMD_0402_1005Metric.step","name":"3DSMD_0402_1005Metric","rawName":"3DSMD_0402_1005Metric.step","storageName":"document_assets/3DSMD_0402_1005Metric-f67a8003-8022-4cca-213f-88262e58f588.step","uid":"f2ad7594-cc63-2059-ba3b-7e66131d1b9f"},"f571b2d1-f0f2-b2f0-b2d5-ed2932e221b7":{"fileType":"kicad_mod","is3dModel":false,"isDefault":false,"isFootprint":false,"isPcbBoardShape":false,"isThumbnail":false,"label":"SMD_MiniMELF_MMA-0204.kicad_mod","name":"SMD_MiniMELF_MMA-0204","rawName":"SMD_MiniMELF_MMA-0204.kicad_mod","storageName":"document_assets/SMD_MiniMELF_MMA-0204-540218ce-3b43-5ef1-50c6-48212839bfdd.kicad_mod","uid":"f571b2d1-f0f2-b2f0-b2d5-ed2932e221b7"},"f5b29da4-1292-c546-20cd-fddf3019f667":{"fileType":"step","is3dModel":false,"isDefault":false,"isFootprint":false,"isPcbBoardShape":false,"isThumbnail":false,"label":"3DSMD_0603_1608Metric.step","name":"3DSMD_0603_1608Metric","rawName":"3DSMD_0603_1608Metric.step","storageName":"document_assets/3DSMD_0603_1608Metric-e9e0c079-dac5-361b-03ae-a1496ca997ab.step","uid":"f5b29da4-1292-c546-20cd-fddf3019f667"},"f5fc4778-d260-d2c1-81a8-c582269fb0ad":{"fileType":"kicad_mod","is3dModel":false,"isDefault":false,"isFootprint":false,"isPcbBoardShape":false,"isThumbnail":false,"label":"SMD_0603_1608Metric.kicad_mod","name":"SMD_0603_1608Metric","rawName":"SMD_0603_1608Metric.kicad_mod","storageName":"document_assets/SMD_0603_1608Metric-81c4836b-6448-8220-0eae-1905ab724f8c.kicad_mod","uid":"f5fc4778-d260-d2c1-81a8-c582269fb0ad"},"f6c513f1-516e-7e9e-0182-25ec594cf2dd":{"fileType":"kicad_mod","is3dModel":false,"isDefault":false,"isFootprint":false,"isPcbBoardShape":false,"isThumbnail":false,"label":"SMD_0815_2038Metric.kicad_mod","name":"SMD_0815_2038Metric","rawName":"SMD_0815_2038Metric.kicad_mod","storageName":"document_assets/SMD_0815_2038Metric-b52f372d-2d5b-aeca-17ec-e0da0fbf2a0e.kicad_mod","uid":"f6c513f1-516e-7e9e-0182-25ec594cf2dd"},"ffa84dad-f46f-7557-fdc4-f32992676362":{"fileType":"kicad_mod","is3dModel":false,"isDefault":false,"isFootprint":false,"isPcbBoardShape":false,"isThumbnail":false,"label":"V_AXIAL-P2.54_D3.2.kicad_mod","name":"V_AXIAL-P2.54_D3.2","rawName":"V_AXIAL-P2.54_D3.2.kicad_mod","storageName":"document_assets/V_AXIAL-P2.54_D3.2-759f8638-2040-9a50-6c53-a792aec7e07d.kicad_mod","uid":"ffa84dad-f46f-7557-fdc4-f32992676362"}},"behaviour":"// Howdy 👋.\n// If you are new to writing code in Flux make sure to check out our get started docs: https://docs.flux.ai/reference/introduction \n// We also have a Flux Slack Community in case you need help: https://join.slack.com/t/fluxcommunity/shared_invite/zt-p48n941f-wzQ06kGmuFJ2HXnGYT1JkA \n// To infinity and beyond 🚀 \n\nconst p1TerminalId = \"dff57d78-487b-f832-db06-4405c23ce37c\"; //P1\nconst p2TerminalId = \"880f28ef-cf41-0acc-4a98-ce0afa37b0c2\"; //P2\n\nconst p1Terminal = flux.getNodeById(p1TerminalId, \"elementTerminal\");\nconst p2Terminal = flux.getNodeById(p2TerminalId, \"elementTerminal\");\n\nconst voltageInputNode = flux.createOutputNode(\"v1\");\nconst voltageOutputNode = flux.createOutputNode(\"v2\");\nconst voltageDrop = flux.createOutputNode(\"vdrop\");\nconst powerOutputNode = flux.createOutputNode(\"power\");\nconst amperageOutputNode = flux.createOutputNode(\"current\");\n\n//setup event\nflux.on(\"setup\", () => {\n    const resistance = Number(flux.properties.find((prop) => prop.name === \"Resistance\")?.value || 500);\n    flux.simulationModel =  simModel(resistance);   \n});\n\n// Property was changed event\nflux.on(\"propertyChange\", (event) => {\n    if (event.property_name === \"Resistance\") {\n        flux.notify(event.property_name + \" changed to \" + event.value + \"Ω\", {\n            variant: \"success\",\n        });\n\n        flux.simulationModel =  simModel(Number(event.value));   \n    }\n});\n\n// Calculation Event\nflux.on(\"afterStep\", () => {\n    const resistance = Number(flux.properties.find((prop) => prop.name === \"Resistance\")?.value || 500);\n    \n    // Equation for power = Current.value to the power of 2 multiply by Resistance // I2R\n    const testABC = Number(p1Terminal?.current);\n    const solveForPower = ((Math.pow(testABC, 2) * resistance) * 1000);\n\n    voltageInputNode.name = \"VP1\";\n    voltageInputNode.value = Number(p1Terminal?.voltage);\n    voltageInputNode.unit = \"V\";\n    voltageInputNode.displayInline = false;\n\n    voltageOutputNode.name = \"VP2\";\n    voltageOutputNode.value = Number(p2Terminal?.voltage);\n    voltageOutputNode.unit = \"V\";\n    voltageOutputNode.displayInline = false;\n\n    amperageOutputNode.name = \"Current\";\n    amperageOutputNode.value = Number(p1Terminal?.current);\n    amperageOutputNode.unit = \"A\";\n    amperageOutputNode.displayInline = true;\n\n    powerOutputNode.name = \"calcPower\";\n    powerOutputNode.value = solveForPower;\n    powerOutputNode.unit = \"mW\";\n    powerOutputNode.displayInline = true;\n\n    voltageDrop.name = \"Vdrop\";\n    voltageDrop.unit =\"V\";\n    voltageDrop.value = Number(p2Terminal?.voltage) - Number(p1Terminal?.voltage);\n    voltageDrop.displayInline = true;\n    \n    flux.outputs = [voltageDrop, voltageInputNode, voltageOutputNode, amperageOutputNode, powerOutputNode];\n});\n\nfunction simModel(resistance: number): ResistorSimulationModelConfig {\n    return {\n        type: \"resistor\",\n        resistance: resistance,\n        map_input_to_terminal_uid: p1TerminalId,\n        map_output_to_terminal_uid: p2TerminalId,\n    };\n}\n\nconst footprintNode = flux.getNodeById(\"bd79d98f-3542-c68b-7d08-c8a9fe1b19d2\") as PcbLayoutNode;\nconst modelNode = flux.getNodeById(\"03889df1-6435-acaa-19c8-c65242c5255a\") as PcbLayoutNode;\n\n// This will return array of all assets with file type .kicad_mod\nconst footprintAssetNotSorted = flux.assets.filter((asset) => asset.fileType === \"kicad_mod\").map((asset) => asset.name);\nconst footprintAssetId = footprintAssetNotSorted.sort();\n\n// This will return array of all assets with file type .step\nconst modelAssetIdNotSorted = flux.assets.filter((asset) => asset.fileType === \"step\").map((asset) => asset.name);\nconst modelAssetId = modelAssetIdNotSorted.sort();\n\nif (footprintNode || modelNode) {\n    const assetFootprintRule = footprintNode.rules.find((rule) => rule.key === \"asset\");\n    const assetModelRule = modelNode.rules.find((rule) => rule.key === \"asset\");\n\n    flux.on(\"setup\", () => {\n        const property = flux.properties.find((prop) => prop.name === \"Package\");\n        if (property) {\n            changeFootprintAsset(property.value);\n            changeModelAsset(property.value)\n        }\n    });\n\n// Listen to any change in the Package property, set the footprint and model \n// based on the current package value.\n    flux.on(\"propertyChange\", (event: PropertyChangeEvent) => {\n        if (event.property_name === \"Package\") {\n            changeFootprintAsset(event.value);\n            changeModelAsset(event.value);\n            flux.notify(event.property_name + \" changed to \" + event.value, {\n                variant: \"success\",\n                });\n        }\n    });\n\n    function changeFootprintAsset(propertyValue: any) {\n        if (assetFootprintRule) {\n            switch (propertyValue) {\n            case footprintAssetId[0]: assetFootprintRule.value = footprintAssetId[0]; footprintNode.name = footprintAssetId[0]; break;\n            case footprintAssetId[1]: assetFootprintRule.value = footprintAssetId[1]; footprintNode.name = footprintAssetId[1]; break;\n            case footprintAssetId[2]: assetFootprintRule.value = footprintAssetId[2]; footprintNode.name = footprintAssetId[2]; break;\n            case footprintAssetId[3]: assetFootprintRule.value = footprintAssetId[3]; footprintNode.name = footprintAssetId[3]; break;\n            case footprintAssetId[4]: assetFootprintRule.value = footprintAssetId[4]; footprintNode.name = footprintAssetId[4]; break;\n            case footprintAssetId[5]: assetFootprintRule.value = footprintAssetId[5]; footprintNode.name = footprintAssetId[5]; break;\n            case footprintAssetId[6]: assetFootprintRule.value = footprintAssetId[6]; footprintNode.name = footprintAssetId[6]; break;\n            case footprintAssetId[7]: assetFootprintRule.value = footprintAssetId[7]; footprintNode.name = footprintAssetId[7]; break;\n            case footprintAssetId[8]: assetFootprintRule.value = footprintAssetId[8]; footprintNode.name = footprintAssetId[8]; break;\n            case footprintAssetId[9]: assetFootprintRule.value = footprintAssetId[9]; footprintNode.name = footprintAssetId[9]; break;\n            case footprintAssetId[10]: assetFootprintRule.value = footprintAssetId[10]; footprintNode.name = footprintAssetId[10]; break;\n            case footprintAssetId[11]: assetFootprintRule.value = footprintAssetId[11]; footprintNode.name = footprintAssetId[11]; break;\n            case footprintAssetId[12]: assetFootprintRule.value = footprintAssetId[12]; footprintNode.name = footprintAssetId[12]; break;\n            case footprintAssetId[13]: assetFootprintRule.value = footprintAssetId[13]; footprintNode.name = footprintAssetId[13]; break;\n            case footprintAssetId[14]: assetFootprintRule.value = footprintAssetId[14]; footprintNode.name = footprintAssetId[14]; break;\n            case footprintAssetId[15]: assetFootprintRule.value = footprintAssetId[15]; footprintNode.name = footprintAssetId[15]; break;   \n            case footprintAssetId[16]: assetFootprintRule.value = footprintAssetId[16]; footprintNode.name = footprintAssetId[16]; break;    \n            case footprintAssetId[17]: assetFootprintRule.value = footprintAssetId[17]; footprintNode.name = footprintAssetId[17]; break;\n            case footprintAssetId[18]: assetFootprintRule.value = footprintAssetId[18]; footprintNode.name = footprintAssetId[18]; break;   \n            case footprintAssetId[19]: assetFootprintRule.value = footprintAssetId[19]; footprintNode.name = footprintAssetId[19]; break;  \n            case footprintAssetId[20]: assetFootprintRule.value = footprintAssetId[20]; footprintNode.name = footprintAssetId[20]; break;    \n            case footprintAssetId[21]: assetFootprintRule.value = footprintAssetId[21]; footprintNode.name = footprintAssetId[21]; break;\n            case footprintAssetId[22]: assetFootprintRule.value = footprintAssetId[22]; footprintNode.name = footprintAssetId[22]; break;\n            case footprintAssetId[23]: assetFootprintRule.value = footprintAssetId[23]; footprintNode.name = footprintAssetId[23]; break;\n            case footprintAssetId[24]: assetFootprintRule.value = footprintAssetId[24]; footprintNode.name = footprintAssetId[24]; break;\n            case footprintAssetId[25]: assetFootprintRule.value = footprintAssetId[25]; footprintNode.name = footprintAssetId[25]; break;\n            case footprintAssetId[26]: assetFootprintRule.value = footprintAssetId[26]; footprintNode.name = footprintAssetId[26]; break;\n            case footprintAssetId[27]: assetFootprintRule.value = footprintAssetId[27]; footprintNode.name = footprintAssetId[27]; break;\n            case footprintAssetId[28]: assetFootprintRule.value = footprintAssetId[28]; footprintNode.name = footprintAssetId[28]; break;\n            case footprintAssetId[29]: assetFootprintRule.value = footprintAssetId[29]; footprintNode.name = footprintAssetId[29]; break;\n            case footprintAssetId[30]: assetFootprintRule.value = footprintAssetId[30]; footprintNode.name = footprintAssetId[30]; break;\n            case footprintAssetId[31]: assetFootprintRule.value = footprintAssetId[31]; footprintNode.name = footprintAssetId[31]; break;\n            case footprintAssetId[32]: assetFootprintRule.value = footprintAssetId[32]; footprintNode.name = footprintAssetId[32]; break;                                    \n            default : assetFootprintRule.value = \"SMD_0603_1608Metric\"; footprintNode.name = \"SMD_0603_1608Metric\"; break;\n            }\n        }\n    }\n\n        function changeModelAsset(propertyValue: any) {\n        if (assetModelRule) {\n            switch (propertyValue) {\n            case footprintAssetId[0]: assetModelRule.value = modelAssetId[0]; modelNode.name = modelAssetId[0]; break;\n            case footprintAssetId[1]: assetModelRule.value = modelAssetId[1]; modelNode.name = modelAssetId[1]; break;\n            case footprintAssetId[2]: assetModelRule.value = modelAssetId[2]; modelNode.name = modelAssetId[2]; break;\n            case footprintAssetId[3]: assetModelRule.value = modelAssetId[3]; modelNode.name = modelAssetId[3]; break;\n            case footprintAssetId[4]: assetModelRule.value = modelAssetId[4]; modelNode.name = modelAssetId[4]; break;\n            case footprintAssetId[5]: assetModelRule.value = modelAssetId[5]; modelNode.name = modelAssetId[5]; break;\n            case footprintAssetId[6]: assetModelRule.value = modelAssetId[6]; modelNode.name = modelAssetId[6]; break;\n            case footprintAssetId[7]: assetModelRule.value = modelAssetId[7]; modelNode.name = modelAssetId[7]; break;\n            case footprintAssetId[8]: assetModelRule.value = modelAssetI